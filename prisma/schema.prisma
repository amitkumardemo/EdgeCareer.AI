generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(uuid())
  uid                    String                  @unique
  email                  String                  @unique
  name                   String?
  imageUrl               String?
  industry               String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  role                   UserRole                @default(STUDENT)
  collegeId              String?
  branch                 String?
  year                   Int?
  section                String?
  rollNumber             String?                 @unique
  githubUsername         String?
  leetcodeUsername       String?
  bio                    String?
  experience             Int?
  points                 Int                     @default(0)
  level                  Int                     @default(1)
  badges                 String                  @default("[]")
  streak                 Int                     @default(0)
  lastActivity           DateTime?
  lastStreakDate         DateTime?
  streakStartDate        DateTime?
  skills                 String                  @default("[]")
  totalResumesCreated    Int                     @default(0)
  totalResumesSaved      Int                     @default(0)
  totalResumesDownloaded Int                     @default(0)
  totalResumesShared     Int                     @default(0)
  totalResumesAnalyzed   Int                     @default(0)
  bestAtsScore           Float?
  lastAtsScore           Float?
  cvLink                 String?
  department             String?
  leetcodeLink           String?
  linkedinLink           String?
  onboardingCompleted    Boolean                 @default(false)
  personalWebsite        String?
  portfolioLink          String?
  resumeLink             String?
  collegeName            String?
  city                   String?
  phone                  String?
  techieId               String?                 @unique
  atsAnalyses            ATSAnalysis[]
  assessments            Assessment[]
  coverLetter            CoverLetter[]
  githubActivities       GitHubActivity[]
  internApplications     InternshipApplication[] @relation("InternApplications")
  mentorBatches          InternshipBatch[]       @relation("BatchMentor")
  leaveRequests          LeaveRequest[]
  loginLogs              LoginLog[]
  mockInterviews         MockInterview[]
  resumes                Resume[]
  submissions            Submission[]
  college                College?                @relation(fields: [collegeId], references: [id])
  industryInsight        IndustryInsight?        @relation(fields: [industry], references: [industry])
  notifications          Notification[]
  videoComments          VideoComment[]

  @@index([collegeId])
  @@index([role])
  @@index([githubUsername])
}

model Question {
  id           String       @id @default(cuid())
  title        String
  slug         String       @unique
  description  String
  difficulty   Difficulty   @default(EASY)
  category     String?
  tags         String[]     @default([])
  constraints  String?
  inputFormat  String?
  outputFormat String?
  starterCode  String       @default("{}")
  published    Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  submissions  Submission[]
  testCases    TestCase[]

  @@index([difficulty])
  @@index([published])
}

model TestCase {
  id             String   @id @default(cuid())
  questionId     String
  input          String
  expectedOutput String
  isHidden       Boolean  @default(true)
  explanation    String?
  question       Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model Submission {
  id              String   @id @default(cuid())
  userId          String
  questionId      String
  language        String
  code            String
  status          String
  verdict         String?
  runtime         Float?
  memory          Int?
  testCasesPassed Int      @default(0)
  totalTestCases  Int      @default(0)
  createdAt       DateTime @default(now())
  question        Question @relation(fields: [questionId], references: [id])
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([questionId])
}

model Assessment {
  id             String   @id @default(cuid())
  userId         String
  quizScore      Float
  questions      String   @default("[]")
  category       String
  improvementTip String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Resume {
  id             String          @id @default(cuid())
  userId         String
  name           String          @default("My Resume")
  content        String
  mode           String          @default("manual")
  status         String          @default("draft")
  atsScore       Float?
  feedback       String?
  downloadCount  Int             @default(0)
  shareCount     Int             @default(0)
  shareToken     String?         @unique
  isPublic       Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  mockInterviews MockInterview[]
  user           User            @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([shareToken])
}

model CoverLetter {
  id             String   @id @default(cuid())
  userId         String
  content        String
  jobDescription String?
  companyName    String
  jobTitle       String
  status         String   @default("draft")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model IndustryInsight {
  id                String   @id @default(cuid())
  industry          String   @unique
  salaryRanges      String   @default("[]")
  growthRate        Float
  demandLevel       String
  topSkills         String   @default("[]")
  marketOutlook     String
  keyTrends         String   @default("[]")
  recommendedSkills String   @default("[]")
  lastUpdated       DateTime @default(now())
  nextUpdate        DateTime
  users             User[]

  @@index([industry])
}

model ATSAnalysis {
  id                 String   @id @default(cuid())
  userId             String
  resumeFileName     String
  atsScore           Float
  scoreCategory      String
  keywordMatchScore  Float
  skillsScore        Float
  formattingScore    Float
  experienceScore    Float
  projectScore       Float
  atsCompatibleScore Float
  matchedKeywords    String   @default("[]")
  missingKeywords    String   @default("[]")
  suggestions        String   @default("[]")
  strengths          String   @default("[]")
  weaknesses         String   @default("[]")
  improvementTip     String?
  comparisonData     String?
  shareToken         String?  @unique
  isPublic           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([shareToken])
}

model MockInterview {
  id            String          @id @default(cuid())
  userId        String
  role          String
  status        InterviewStatus @default(IN_PROGRESS)
  resumeId      String?
  resumeText    String?
  candidateName String?
  overallScore  Float?
  feedback      String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  resume        Resume?         @relation(fields: [resumeId], references: [id])
  user          User            @relation(fields: [userId], references: [id])
  rounds        MockRound[]

  @@index([userId])
  @@index([resumeId])
}

model MockRound {
  id          String        @id @default(cuid())
  interviewId String
  roundNumber Int
  type        RoundType
  status      RoundStatus   @default(PENDING)
  score       Float?
  questions   String        @default("[]")
  answers     String        @default("[]")
  feedback    String?
  startTime   DateTime?
  endTime     DateTime?
  interview   MockInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId])
}

model College {
  id          String       @id @default(uuid())
  name        String
  domain      String       @unique
  location    String?
  type        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  githubSyncs GitHubSync[]
  users       User[]

  @@index([domain])
}

model GitHubActivity {
  id           String   @id @default(uuid())
  userId       String
  date         DateTime @default(now())
  commits      Int      @default(0)
  pullRequests Int      @default(0)
  issues       Int      @default(0)
  reviews      Int      @default(0)
  repositories String   @default("[]")
  languages    String   @default("{}")
  isActive     Boolean  @default(false)
  fetchedAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model GitHubSync {
  id                String     @id @default(uuid())
  collegeId         String?
  userId            String?
  status            SyncStatus @default(PENDING)
  startedAt         DateTime   @default(now())
  completedAt       DateTime?
  studentsProcessed Int        @default(0)
  studentsFailed    Int        @default(0)
  rateLimitHit      Boolean    @default(false)
  rateLimitResetAt  DateTime?
  errors            String     @default("[]")
  college           College?   @relation(fields: [collegeId], references: [id])

  @@index([collegeId])
  @@index([status])
}

model StudentRanking {
  id               String   @id @default(uuid())
  userId           String   @unique
  collegeId        String
  commitScore      Float    @default(0)
  prScore          Float    @default(0)
  issueScore       Float    @default(0)
  consistencyScore Float    @default(0)
  overallScore     Float    @default(0)
  collegeRank      Int?
  branchRank       Int?
  yearRank         Int?
  lastCalculated   DateTime @default(now())

  @@index([collegeId])
  @@index([overallScore])
}

model InternshipProgram {
  id          String            @id @default(uuid())
  title       String
  description String
  domain      String
  duration    Int
  stipend     Float?
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  batches     InternshipBatch[]

  @@index([domain])
  @@index([isActive])
}

model InternshipBatch {
  id            String                  @id @default(uuid())
  programId     String
  name          String
  startDate     DateTime
  endDate       DateTime
  maxStudents   Int                     @default(100)
  status        BatchStatus             @default(UPCOMING)
  mentorId      String?
  description   String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  announcements Announcement[]
  applications  InternshipApplication[]
  mentor        User?                   @relation("BatchMentor", fields: [mentorId], references: [id])
  program       InternshipProgram       @relation(fields: [programId], references: [id], onDelete: Cascade)
  tasks         InternshipTask[]
  leaveRequests LeaveRequest[]
  modules       InternshipModule[]

  @@index([programId])
  @@index([status])
  @@index([mentorId])
}

model InternshipApplication {
  id               String                @id @default(uuid())
  userId           String
  batchId          String
  status           ApplicationStatus     @default(APPLIED)
  resumeUrl        String?
  coverNote        String?
  appliedAt        DateTime              @default(now())
  reviewedAt       DateTime?
  reviewNotes      String?
  attendance       AttendanceRecord[]
  progress         InternProgress?
  batch            InternshipBatch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user             User                  @relation("InternApplications", fields: [userId], references: [id], onDelete: Cascade)
  offerLetter      OfferLetter?
  submissions      TaskSubmission[]
  videoCompletions VideoCompletion[]
  evaluation       InternshipEvaluation?

  @@unique([userId, batchId])
  @@index([userId])
  @@index([batchId])
  @@index([status])
}

model OfferLetter {
  id            String                @id @default(uuid())
  applicationId String                @unique
  pdfUrl        String?
  generatedAt   DateTime              @default(now())
  validUntil    DateTime?
  downloadCount Int                   @default(0)
  application   InternshipApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model InternshipTask {
  id          String           @id @default(uuid())
  batchId     String
  title       String
  description String
  dueDate     DateTime
  maxScore    Float            @default(100)
  resources   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  batch       InternshipBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  submissions TaskSubmission[]

  @@index([batchId])
  @@index([dueDate])
}

model TaskSubmission {
  id            String                 @id @default(uuid())
  applicationId String
  taskId        String
  fileUrl       String?
  notes         String?
  score         Float?
  feedback      String?
  status        InternSubmissionStatus @default(PENDING)
  submittedAt   DateTime               @default(now())
  evaluatedAt   DateTime?
  application   InternshipApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  task          InternshipTask         @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([applicationId, taskId])
  @@index([applicationId])
  @@index([taskId])
  @@index([status])
}

model AttendanceRecord {
  id            String                @id @default(uuid())
  applicationId String
  date          DateTime              @db.Date
  present       Boolean               @default(false)
  markedBy      String?
  note          String?
  application   InternshipApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, date])
  @@index([applicationId])
  @@index([date])
}

model InternProgress {
  id             String                 @id @default(uuid())
  applicationId  String                 @unique
  progressPct    Float                  @default(0)
  performScore   Float                  @default(0)
  tasksCompleted Int                    @default(0)
  totalTasks     Int                    @default(0)
  attendancePct  Float                  @default(0)
  completed      Boolean                @default(false)
  completedAt    DateTime?
  updatedAt      DateTime               @updatedAt
  application    InternshipApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  certificate    InternshipCertificate?
  report         InternshipReport?
}

model InternshipCertificate {
  id            String         @id @default(uuid())
  progressId    String         @unique
  pdfUrl        String?
  issuedAt      DateTime       @default(now())
  serialNo      String         @unique @default(cuid())
  downloadCount Int            @default(0)
  progress      InternProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  @@index([serialNo])
}

model InternshipReport {
  id            String         @id @default(uuid())
  progressId    String         @unique
  pdfUrl        String?
  generatedAt   DateTime       @default(now())
  downloadCount Int            @default(0)
  progress      InternProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  @@index([progressId])
}

model Announcement {
  id        String           @id @default(uuid())
  batchId   String?
  title     String
  body      String
  isGlobal  Boolean          @default(false)
  createdBy String?
  createdAt DateTime         @default(now())
  batch     InternshipBatch? @relation(fields: [batchId], references: [id])

  @@index([batchId])
  @@index([isGlobal])
  @@index([createdAt])
}

model LoginLog {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String?
  userAgent String?
  loginAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LeaveRequest {
  id            String          @id @default(cuid())
  userId        String
  fullName      String
  email         String
  contactNumber String
  department    String?
  leaveType     String
  startDate     DateTime
  endDate       DateTime
  reason        String
  workHandover  String?
  attachmentUrl String?
  status        LeaveStatus     @default(PENDING)
  adminNotes    String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  batchId       String
  batch         InternshipBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([batchId])
  @@index([status])
}

enum UserRole {
  STUDENT
  TPO
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum InterviewStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum RoundType {
  APTITUDE
  TECHNICAL
  HR
}

enum RoundStatus {
  PENDING
  IN_PROGRESS
  PASSED
  FAILED
}

enum SyncStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum ApplicationStatus {
  APPLIED
  UNDER_REVIEW
  SELECTED
  REJECTED
}

enum BatchStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum InternTaskStatus {
  PENDING
  SUBMITTED
  EVALUATED
}

enum InternSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_REVISION
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model InternshipModule {
  id          String   @id @default(uuid())
  batchId     String
  title       String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  batch  InternshipBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  videos InternshipVideo[]

  @@index([batchId])
}

model InternshipVideo {
  id        String   @id @default(uuid())
  moduleId  String
  title     String
  videoUrl  String
  youtubeId String?
  thumbnail String?
  duration  String?
  order     Int      @default(0)
  resources String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  module      InternshipModule  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  completions VideoCompletion[]
  comments    VideoComment[]

  @@index([moduleId])
}

model VideoComment {
  id        String   @id @default(uuid())
  videoId   String
  userId    String
  text      String
  parentId  String? 
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  video     InternshipVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    VideoComment?   @relation("CommentToReply", fields: [parentId], references: [id])
  replies   VideoComment[]  @relation("CommentToReply")
  
  @@index([videoId])
}

model VideoCompletion {
  id            String   @id @default(uuid())
  applicationId String
  videoId       String
  completedAt   DateTime @default(now())

  application InternshipApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  video       InternshipVideo       @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([applicationId, videoId])
  @@index([applicationId])
  @@index([videoId])
}

model InternshipEvaluation {
  id                      String    @id @default(uuid())
  applicationId           String    @unique
  technicalSkills         String
  practicalImplementation String
  communication           String
  teamwork                String
  timeManagement          String
  learningAbility         String
  initiative              String
  professionalEthics      String
  technicalComments       String?
  practicalComments       String?
  communicationComments   String?
  teamworkComments        String?
  disciplineComments      String?
  strengths               String?
  growthAreas             String?
  comments                String?
  summary                 String?
  publishedAt             DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  application InternshipApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([createdAt])
}
